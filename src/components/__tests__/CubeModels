            className="ant-card-meta-description"
            initial={{ y: -10, opacity: 0 }}
            animate={isActive ? { y: 0, opacity: 1 } : {}}
            transition={{ 
              type: "spring",
              stiffness: 120,
              damping: 15,
              delay: isActive ? 0.1 : 0
            }}
          >
            {description}
          </motion.p>
          <motion.div 
            className="features-list"
            initial={{ y: 10, opacity: 0 }}
            animate={isActive ? { y: 0, opacity: 1 } : {}}
            transition={{ 
              type: "spring",
              stiffness: 100,
              damping: 12,
              delay: isActive ? 0.2 : 0
            }}
          >
            {tags.map((tag, index) => (
              <motion.span 
                key={index} 
                className="feature-tag"
                initial={{ scale: 0 }}
                animate={{ scale: 1 }}
                transition={{ 
                  type: "spring",
                  stiffness: 150,
                  damping: 10,
                  delay: isActive ? index * 0.05 : 0
                }}
              >
                {tag}
              </motion.span>
            ))}
          </motion.div>
        </div>
      </motion.div>
    </div>
  );
};

function MaterialsPage() {
  const { theme } = useTheme();

  return (
    <motion.div
      className={`materials-page ${theme}`}
      initial={{ opacity: 0, y: 50 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -50 }}
      transition={{ duration: 0.3, ease: "easeInOut", type: "spring" }}
      data-theme={theme}
    >
      <div className="materials-header">
        <h1>Премиальные материалы</h1>
        <p>Мы тщательно отбираем лучшие материалы для наших изделий</p>
      </div>
      
      <div className="materials-grid">
        {materials.map(material => (
          <motion.div
            key={material.id}
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: "-20%" }}
            transition={{ duration: 0.3, ease: "easeInOut", type: "spring" }}
          >
            <Card
              title={material.title}
              image={material.image}
              description={material.description}
              tags={material.features}
            />
          </motion.div>
        ))}
      </div>
    </motion.div>
  );
}

export default MaterialsPage; 








// MaterialsPage.less
.materials-page {
  padding: 1rem;
  border-radius: 1rem;
  max-width: 1600px;
  margin: 0 auto;
  
  // CSS переменные
  --text-primary: var(--primary-color);
  --text-secondary: var(--text-color);
  --bg-primary: var(--page-bg);
  --card-bg: var(--secondary-bg);
  --feature-tag-bg: var(--background-color-light);
  --feature-tag-color: var(--text-color);
  --overlay-gradient: linear-gradient(transparent, rgba(0,0,0,0.9));
  --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
  --active-card-shadow: 0 15px 30px rgba(0,0,0,0.55);
  --card-title-color: #2d3748;
  --title-shadow-color: rgba(0,0,0,0.2);

  .materials-header {
    text-align: center;
    margin-bottom: 40px;
    
    h1 {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
      transition: color 0.3s var(--theme-transition, ease-in-out);
    }
    
    p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      transition: color 0.3s var(--theme-transition, ease-in-out);
    }
  }

  .materials-grid {
    height: 100%;
    width: auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    // padding: 0 2rem;
  }

  .material-card {
    background: var(--card-bg);
    border-radius: 20px;
    overflow: visible;
    transition: transform 0.5s var(--ease-in-out), 
                box-shadow 0.5s var(--ease-out-back),
                opacity 0.3s var(--ease-in-out);
    transform-origin: center;
    will-change: transform;
    position: relative;
    z-index: 1;
    box-shadow: var(--card-shadow);
    
  
    &:hover {
      transform: translateY(-8px) scale(1.02);
      box-shadow: var(--active-card-shadow);
      transition-duration: 0.4s;
      transition-timing-function: var(--ease-in-out);
    }

    &.active {
      transition-duration: 0.4s;
      transition-timing-function: var(--ease-in-out);
    }

    &:not(.active) {
      transition-duration: 0.4s;
      transition-timing-function: var(--ease-in-out);
    }

    .ant-card-cover {
      position: relative;
      height: 250px;
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s var(--ease-in-out);
      }
    }

    .card-title-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--overlay-gradient);
      padding: 1rem;
      z-index: 2;
      transition: all 0.3s var(--ease-in-out);
      display: flex;
      align-items: flex-end;
      min-height: 50%;

      .card-title {
        color: var(--card-title-color);
        font-size: 1.2rem;
        margin: 0;
        transition: transform 0.3s var(--ease-in-out);
        text-shadow: 0 2px 4px var(--title-shadow-color);
      }

      &:hover .card-title {
        transform: translateY(0);
      }

      &.active .card-title {
        transform: translateY(0);
        opacity: 0.9;
      }
    }

    .card-content {
      overflow: hidden;
      background: var(--card-bg);
      transition: background 0.3s var(ease-in-out);
      border-radius: 0 0 20px 20px;
      
      .ant-card-body {
        padding: 1.5rem;
        background: var(--card-bg);
        border-radius: 0 0 20px 20px;
      }

      .ant-card-meta-description {
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 1rem;
      }

      .features-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;

        .feature-tag {
          background: var(--feature-tag-bg);
          transition: background 0.3s var(--ease-in-out);
          color: var(--feature-tag-color);
          padding: 4px 12px;
          border-radius: 20px;
          font-size: 0.9rem;
        }
      }
    }
  }
}

// Темная тема
[data-theme='dark'] {
  .materials-page {
    --text-primary: #f8f9fa;
    --text-secondary: #e2e8f0;
    --card-bg: #2d2d2d;
    --overlay-gradient: linear-gradient(transparent, rgba(0,0,0,0.8));
    --feature-tag-bg: #83653F;
    --feature-tag-color: #fff;
    --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
    --active-card-shadow: 0 15px 30px rgba(0,0,0,0.5);
    --title-shadow-color: rgba(0,0,0,0.7);
    --card-title-color: #f8f9fa;

    .card-title-overlay {
      background: linear-gradient(transparent, rgba(0,0,0,0.8));
      transition: background 0.3s var(--ease-in-out);
    }
  }
}

// Светлая тема
[data-theme='light'] {
  .materials-page {
    --title-shadow-color: rgba(255, 255, 255, 0.2);
    --card-title-color: #fff;
    --feature-tag-bg: #83653F;
    --feature-tag-color: #fff;
  }
}

// Адаптив
@media (max-width: @screen-sm) {
  .materials-page {
    min-height: 80vh;
    padding: 1rem;

    .materials-header {
      margin-bottom: 2rem;
      
      h1 {
        font-size: 2rem;
      }
      
      p {
        font-size: 1rem;
      }
    }

    .material-card {
      .ant-card-cover {
        height: 200px;
        width: auto;
      }

      .card-title-overlay .card-title {
        font-size: 1rem;
      }

      .card-content .ant-card-body {
        padding: 1rem;
      }
    }
  }
}

// Добавляем глобальные настройки анимаций
[data-theme] {
  transition: background 0.6s var(--ease-in-out), 
              color 0.6s var(--ease-in-out);
}